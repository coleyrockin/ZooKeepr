PORT=3001
NODE_ENV=development
ZOO_WRITES_ENABLED=false
ZOO_WRITE_TOKEN=replace-me-with-random-string
ZOO_WRITE_RATE_LIMIT=30
# Set only when behind a known reverse proxy (e.g. Heroku=1, Cloudflare=specific subnet).
# Leaving unset disables X-Forwarded-For trust so rate-limit bypass via spoofed
# headers is not possible.
# TRUST_PROXY=1
